# E2E environment variables for Playwright tests
# Copy this file to .env.e2e and fill in the values.
# NEVER commit .env.e2e – it contains real credentials.

# Base URL of the environment to test against
E2E_BASE_URL="https://vogatchi-voyage-connect.lovable.app/"

# Super-admin credentials
E2E_SUPER_ADMIN_EMAIL="admin@vogatchi.com"
E2E_SUPER_ADMIN_PASSWORD="Admin@123456"
